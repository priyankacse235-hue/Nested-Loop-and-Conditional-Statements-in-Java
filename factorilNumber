import java.util.Scanner;
public class solution{
   public static void main(String[] args){
    Scanner sc = new Scanner(System.in);

    int fact = 1;
    int num;

    System.out.println("Enter your positive integer :");
    num = sc.nextInt();
    for(int i=1; i<=num; i++){
      fact*=i;
    }
    System.out.println("Factorial"+ " "+fact);
    

    } 
}
