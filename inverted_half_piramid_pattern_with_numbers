public class patterns {
    public static void inverted_rotated_half_pyramid(int n){
        //outerloop
        for(int i=1; i<=n; i++){
        // spaces
          for(int j=1; j<=n-i+1; j++){
        
            System.out.print(j);
          }
          
          System.out.println();
      }
    }

    public static void main(String args[]){
        inverted_rotated_half_pyramid(5);

    }

}
